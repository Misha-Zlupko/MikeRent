generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApartmentType {
  APARTMENT
  HOUSE
  ROOM
}

enum ApartmentCategory {
  EXCLUSIVE
  SHARED
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Apartment {
  id            String        @id @default(cuid())
  title         String
  type          ApartmentType
  category      ApartmentCategory @default(EXCLUSIVE)

  city          String
  address       String
  ownerName     String? // лише для адмінки — ім'я власника/хазяїна
  ownerPhone    String? // лише для адмінки — телефон хазяїна квартири
  lastCalledAt  DateTime? // позначка останнього прозвону (скидається логічно через 12 год)

  ownerPrice    Int           @default(0) // ціна власника за ніч (адмінка)
  markup        Int           @default(0) // націнка за ніч (адмінка)
  pricePerNight Int

  guests        Int
  bedrooms      Int
  beds          Int
  bathrooms     Int

  images        String[]
  description   String
  mapUrl        String
  amenities     String[]


  availability    Json?      
  bookings        Booking[]
  bookingRequests BookingRequest[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// Соответствует booked[] внутри availability
model Booking {
  id          String    @id @default(cuid())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  apartmentId String

  // Дати бронювання
  dateFrom    DateTime
  dateTo      DateTime

  // Інформація про клієнта
  guestName   String?   // ім'я клієнта
  guestPhone  String?   // номер телефону
  guestCount  Int?      // кількість людей
  guestContact String?  // telegram/viber/whatsapp

  // Фінанси
  totalAmount Float?    // сума, яку заплатив клієнт
  ownerPayout Float?    // скільки віддати хазяїну
  ourProfit   Float?    // наш заробіток (totalAmount - ownerPayout)
  ownerPhone  String?   // номер хазяїна для зв'язку

  // Службова інформація
  createdAt   DateTime  @default(now())
  status      BookingStatus @default(PENDING)

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum BookingRequestStatus {
  NEW
  CALLED
  CONFIRMED
  REJECTED
}

model BookingRequest {
  id            String               @id @default(cuid())
  bookingNumber String               @unique
  apartment     Apartment            @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  apartmentId   String

  phone         String
  comment       String?
  guests        Int
  nights        Int
  checkIn       DateTime
  checkOut      DateTime
  totalPrice    Float

  status        BookingRequestStatus @default(NEW)
  calledAt      DateTime?
  processedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

// Отзывы на главной — по твоему Comment из CommentsDataTypes.ts
model Testimonial {
  id      String   @id @default(cuid())
  name    String
  text    String
  avatar  String
  date    DateTime // можно хранить как дату, даже если сейчас у тебя строка

  createdAt DateTime @default(now())
}

model ActiveUser {
  sessionId    String   @id
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}