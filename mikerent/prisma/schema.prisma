generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApartmentType {
  APARTMENT
  HOUSE
  ROOM
}

enum ApartmentCategory {
  EXCLUSIVE
  SHARED
}

enum AdminRole {
  OWNER
  WORKER
}

model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      AdminRole @default(WORKER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Apartment {
  id            String        @id @default(cuid())
  title         String
  type          ApartmentType
  category      ApartmentCategory @default(EXCLUSIVE)

  city          String
  address       String
  seaDistanceMin Int?
  seaDistanceMax Int?
  ownerName     String? // лише для адмінки — ім'я власника/хазяїна
  ownerPhone    String? // лише для адмінки — телефон хазяїна квартири
  lastCalledAt  DateTime? // позначка останнього прозвону (скидається логічно через 12 год)

  ownerPrice    Int           @default(0) // ціна власника за ніч (адмінка)
  markup        Int           @default(0) // націнка за ніч (адмінка)
  pricePerNight Int

  guests        Int
  bedrooms      Int
  beds          Int
  bathrooms     Int

  images        String[]
  /// Фото на картці головної сторінки (одне з images)
  coverImageUrl String?
  description   String
  mapUrl        String
  amenities     String[]

  /// Поверх квартири (опційно), наприклад 3
  floor           Int?
  /// Скільки поверхів у будинку (опційно), наприклад 9
  totalFloors     Int?
  /// Посилання на відеоогляд (YouTube тощо), опційно
  videoTourUrl    String?

  availability    Json?      
  bookings        Booking[]
  bookingRequests BookingRequest[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// Соответствует booked[] внутри availability
model Booking {
  id          String    @id @default(cuid())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  apartmentId String

  // Дати бронювання
  dateFrom    DateTime
  dateTo      DateTime

  // Інформація про клієнта
  guestName   String?   // ім'я клієнта
  guestPhone  String?   // номер телефону
  guestCount  Int?      // кількість людей
  guestContact String?  // telegram/viber/whatsapp

  // Фінанси
  totalAmount Float?    // сума, яку заплатив клієнт
  ownerPayout Float?    // скільки віддати хазяїну
  ourProfit   Float?    // наш заробіток (totalAmount - ownerPayout)
  prepaidToMe    Float? // передоплата, яку отримав адмін (у форматі БД /42)
  prepaidToOwner Float? // передоплата, яку отримав хазяїн (у форматі БД /42)
  paymentStatus  PaymentStatus @default(UNPAID)
  ownerPhone  String?   // номер хазяїна для зв'язку
  recordType    BookingRecordType @default(AGENCY)

  // Службова інформація
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  status      BookingStatus @default(PENDING)

  @@map("bookings")
}

model Guest {
  id              String   @id @default(cuid())
  phoneNormalized String   @unique
  name            String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MessageTemplate {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  adminEmail String
  entityType String
  entityId   String
  action     String
  summary    String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  UNPAID
  PREPAID_RECEIVED
  BALANCE_AT_CHECKIN
  PAID_IN_FULL
}

/// AGENCY — ваші клієнти (список бронювань); OWNER / EXTERNAL — лише зайнятість на картці квартири
enum BookingRecordType {
  AGENCY
  OWNER
  EXTERNAL
}

enum BookingRequestStatus {
  NEW
  CALLED
  CONFIRMED
  REJECTED
}

model BookingRequest {
  id            String               @id @default(cuid())
  bookingNumber String               @unique
  apartment     Apartment            @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  apartmentId   String

  phone         String
  comment       String?
  guests        Int
  nights        Int
  checkIn       DateTime
  checkOut      DateTime
  totalPrice    Float

  status        BookingRequestStatus @default(NEW)
  calledAt      DateTime?
  processedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

// Отзывы на главной — по твоему Comment из CommentsDataTypes.ts
model Testimonial {
  id      String   @id @default(cuid())
  name    String
  text    String
  avatar  String
  date    DateTime // можно хранить как дату, даже если сейчас у тебя строка

  createdAt DateTime @default(now())
}

model ActiveUser {
  sessionId    String   @id
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}